{
  "name": "ping-backend",
  "version": "1.0.0",
  "description": "Ping - Private emotional connection app for couples",
  "author": "",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "build": "nest build",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "jest --config ./test/jest-e2e.json",
    "get:firebase-id-token": "node scripts/get-firebase-id-token.cjs"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1033.0",
    "@aws-sdk/client-secrets-manager": "^3.1024.0",
    "@aws-sdk/client-ses": "^3.1024.0",
    "@aws-sdk/s3-presigned-post": "^3.1033.0",
    "@aws-sdk/s3-request-presigner": "^3.1033.0",
    "@nestjs/common": "^11.1.18",
    "@nestjs/config": "^4.0.0",
    "@nestjs/core": "^11.1.18",
    "@nestjs/mongoose": "^11.0.0",
    "@nestjs/passport": "^11.0.0",
    "@nestjs/platform-express": "^11.1.18",
    "@nestjs/swagger": "^11.0.0",
    "@nestjs/throttler": "^6.4.0",
    "axios": "1.15.0",
    "bcrypt": "^6.0.0",
    "chalk": "^4.1.2",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "compression": "^1.7.5",
    "escape-html": "^1.0.3",
    "firebase-admin": "^13.7.0",
    "helmet": "^8.0.0",
    "hpp": "^0.2.3",
    "ioredis": "^5.10.1",
    "joi": "^18.1.2",
    "mongo-sanitize": "^1.1.0",
    "mongoose": "^8.8.3",
    "morgan": "^1.10.0",
    "nestjs-i18n": "^10.4.9",
    "openai": "^6.33.0",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "rate-limiter-flexible": "^5.0.5",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "winston": "^3.17.0",
    "winston-daily-rotate-file": "^5.0.0",
    "@nestjs/event-emitter": "^3.0.0",
    "@nestjs/jwt": "^11.0.0",
    "@nestjs/platform-socket.io": "^11.1.18",
    "@nestjs/schedule": "^5.0.0",
    "@nestjs/websockets": "^11.1.18",
    "bullmq": "^5.38.0",
    "socket.io": "^4.8.1",
    "uuid": "^11.1.0"
  },
  "devDependencies": {
    "@faker-js/faker": "^10.4.0",
    "@nestjs/cli": "^11.0.17",
    "@nestjs/schematics": "^11.0.10",
    "@nestjs/testing": "^11.1.18",
    "@types/bcrypt": "^6.0.0",
    "@types/compression": "^1.7.5",
    "@types/escape-html": "^1.0.4",
    "@types/express": "^5.0.0",
    "@types/hpp": "^0.2.7",
    "@types/jest": "^29.5.14",
    "@types/morgan": "^1.9.9",
    "@types/node": "^22.10.2",
    "@types/passport": "^1.0.17",
    "@types/passport-jwt": "^4.0.1",
    "@types/supertest": "^6.0.2",
    "@types/uuid": "^10.0.0",
    "@typescript-eslint/eslint-plugin": "^8.18.0",
    "@typescript-eslint/parser": "^8.18.0",
    "eslint": "^9.17.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.2.1",
    "jest": "^29.7.0",
    "mongodb-memory-server": "^11.0.1",
    "prettier": "^3.4.2",
    "source-map-support": "^0.5.21",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.5",
    "ts-loader": "^9.5.1",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.7.2"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s",
      "!**/*.module.ts",
      "!**/*.dto.ts",
      "!**/main.ts",
      "!**/*.d.ts",
      "!**/express.d.ts"
    ],
    "coverageDirectory": "../coverage",
    "coverageProvider": "v8",
    "testEnvironment": "node",
    "coverageThreshold": {
      "global": {
        "statements": 80,
        "branches": 80,
        "functions": 80,
        "lines": 80
      }
    },
    "moduleNameMapper": {
      "^@common/(.*)$": "<rootDir>/common/$1",
      "^@config/(.*)$": "<rootDir>/config/$1",
      "^@database/(.*)$": "<rootDir>/database/$1",
      "^src/(.*)$": "<rootDir>/$1"
    }
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "overrides": {
    "protobufjs": "^7.5.5",
    "file-type": "^21.3.2",
    "js-yaml": "^4.1.1",
    "lodash": "^4.18.0",
    "multer": "^2.1.1",
    "nodemailer": "^8.0.4",
    "@tootallnate/once": "^3.0.1",
    "path-to-regexp": "^8.4.0",
    "picomatch": "^4.0.4",
    "tmp": "^0.2.4",
    "webpack": "^5.105.1"
  }
}
