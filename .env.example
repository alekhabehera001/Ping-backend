# App
NODE_ENV=development
PORT=3000

# MongoDB
MONGO_URI=mongodb://localhost:27017/ping-db

# JWT (base64-encoded RS256 private keys or long random strings for HS256)
JWT_SECRET=your-super-secret-jwt-key-minimum-32-characters-long
JWT_EXPIRE_SECONDS=15m
JWT_REFRESH_SECRET=your-super-secret-refresh-key-minimum-32-characters-long
JWT_REFRESH_EXPIRE_SECONDS=7d

# API Security
API_KEY=your-api-key-min-8-chars
CORS_ORIGINS=http://localhost:3000,http://localhost:19006

# AWS (optional - skip for local dev)
SKIP_AWS_SECRETS=true
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=ping-app-memories
AWS_SES_FROM_EMAIL=noreply@yourdomain.com

# Firebase (optional - for push notifications)
FIREBASE_PROJECT_ID=
FIREBASE_PRIVATE_KEY=
FIREBASE_CLIENT_EMAIL=

# Redis (optional - for caching/queues)
REDIS_HOST=localhost
REDIS_PORT=6379

# OTP
OTP_EXPIRY_MINUTES=5
